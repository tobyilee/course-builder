# AI Course Builder — environment template
# Usage: cp .env.example .env && vi .env
# All values are read via `source .env` from the project root.

# OpenAI API key (required for TTS synthesis with gpt-4o-mini-tts)
# Create at: https://platform.openai.com/api-keys
# Format: project-scoped key, starts with sk-proj- (~164 chars)
export OPENAI_API_KEY=sk-proj-REPLACE_ME

# Optional: override default TTS engine (openai | edge)
# export TTS_ENGINE=openai

# Optional: override default TTS voice (nova | shimmer | alloy | ...)
# export TTS_VOICE=nova
